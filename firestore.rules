rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — owner can write; any signed-in user can read (needed for friends)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Games — owner writes; friends can read
      match /games/{gameId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Play log — private to owner
      match /playLog/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Friendships — owner only
    match /friendships/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Game nights — attendees can read and update (RSVP + votes); host can do everything
    match /gameNights/{nightId} {
      allow read: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.attendeeUids);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostUid &&
        request.auth.uid in request.resource.data.attendeeUids;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.attendeeUids;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.hostUid;
    }
  }
}